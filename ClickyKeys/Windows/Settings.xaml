<Window x:Class="ClickyKeys.Settings"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ClickyKeys"
        mc:Ignorable="d"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="ClickyKeys Settings"
        Width="490" Height="780"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Closing="Window_Closed"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.FontFamily="Segoe UI"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}">

    <Window.Resources>
        <!--
          Shared layout for a single setting row: a description on the left
          that takes the remaining width, and the control (switch / combo)
          pinned to the right. Applied to the Grid that wraps each row so all
          rows line up consistently regardless of label length.
        -->
        <Style x:Key="SettingRowGrid" TargetType="Grid">
            <Setter Property="Margin" Value="0,6,0,6"/>
        </Style>
        <Style x:Key="SettingLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12" VerticalAlignment="Center">
            <Image Width="60" Height="60" Source="/Resources/Buttons/settings_icon.png" Margin="0,0,12,0"/>
            <StackPanel>
                <TextBlock Text="Settings"
                           FontSize="24"
                           FontWeight="Bold"/>
                <TextBlock Text="Configure ClickyKeys"
                           FontSize="13"
                           Foreground="{DynamicResource MaterialDesignBodyLight}"/>
            </StackPanel>
        </StackPanel>

        <!-- Main content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,0,8">

                <!-- ============================================================
                     Category: Data Collection
                     All switches here are UI-only for now. They will later be
                     bound to the data-collection services (uptime tracker and
                     KeyStatsService). See Settings.xaml.cs for wiring notes.
                     ============================================================ -->
                <materialDesign:Card Margin="0,0,0,12" Padding="12">
                    <StackPanel>
                        <TextBlock Text="Data Collection"
                                   FontWeight="Bold"
                                   FontSize="14"
                                   Margin="0,0,0,6"/>

                        <!-- 1. Collect application uptime data -->
                        <Grid Style="{StaticResource SettingRowGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Style="{StaticResource SettingLabel}"
                                       Text="Collect application uptime data"/>
                            <ToggleButton Grid.Column="1"
                                          x:Name="CollectUptimeToggle"
                                          Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                          Checked="CollectUptimeToggle_Changed"
                                          Unchecked="CollectUptimeToggle_Changed"/>
                        </Grid>

                        <!-- 2. Collect key-press statistics -->
                        <Grid Style="{StaticResource SettingRowGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Style="{StaticResource SettingLabel}"
                                       Text="Collect key-press statistics"/>
                            <ToggleButton Grid.Column="1"
                                          x:Name="CollectKeyStatsToggle"
                                          Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                          Checked="CollectKeyStatsToggle_Changed"
                                          Unchecked="CollectKeyStatsToggle_Changed"/>
                        </Grid>
                    </StackPanel>
                </materialDesign:Card>

                <!-- ============================================================
                     Category: Usage
                     Autostart and start-minimized are OS-integration toggles;
                     language switching requires reloading localized resources.
                     All are UI-only placeholders for now — see code-behind.
                     ============================================================ -->
                <materialDesign:Card Margin="0,0,0,12" Padding="12">
                    <StackPanel>
                        <TextBlock Text="Usage"
                                   FontWeight="Bold"
                                   FontSize="14"
                                   Margin="0,0,0,6"/>

                        <!-- 1. Launch on system startup (autostart) -->
                        <Grid Style="{StaticResource SettingRowGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Style="{StaticResource SettingLabel}"
                                       Text="Launch on system startup"/>
                            <ToggleButton Grid.Column="1"
                                          x:Name="AutostartToggle"
                                          Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                          Checked="AutostartToggle_Changed"
                                          Unchecked="AutostartToggle_Changed"/>
                        </Grid>

                        <!-- 2. Start minimized -->
                        <Grid Style="{StaticResource SettingRowGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Style="{StaticResource SettingLabel}"
                                       Text="Start minimized"/>
                            <ToggleButton Grid.Column="1"
                                          x:Name="StartMinimizedToggle"
                                          Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                          Checked="StartMinimizedToggle_Changed"
                                          Unchecked="StartMinimizedToggle_Changed"/>
                        </Grid>

                        <!-- 3. Language selector -->
                        <Grid Style="{StaticResource SettingRowGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Style="{StaticResource SettingLabel}"
                                       Text="Language"/>
                            <ComboBox Grid.Column="1"
                                      x:Name="LanguageComboBox"
                                      MinWidth="140"
                                      VerticalAlignment="Center"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      SelectionChanged="LanguageComboBox_SelectionChanged">
                                <!-- Tag holds the culture code the wiring layer
                                     will eventually read; Content is the
                                     user-facing label. -->
                                <ComboBoxItem Content="English" Tag="en" IsSelected="True"/>
                                <ComboBoxItem Content="Polski" Tag="pl"/>
                            </ComboBox>
                        </Grid>
                    </StackPanel>
                </materialDesign:Card>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <DockPanel Grid.Row="2" Margin="0,8,0,0">
            <Button DockPanel.Dock="Right"
                    Width="80"
                    Margin="0,0,10,0"
                    Content="Close"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    IsCancel="True"
                    Click="Click_Close"/>
        </DockPanel>
    </Grid>
</Window>
