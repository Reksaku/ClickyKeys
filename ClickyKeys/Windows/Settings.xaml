<Window x:Class="ClickyKeys.Settings"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ClickyKeys"
        mc:Ignorable="d"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="{DynamicResource Settings_Title}"
        Width="490" Height="830"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Closing="Window_Closed"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.FontFamily="Segoe UI"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}">

    <Window.Resources>
        <!--
          Shared layout for a single setting row: a description on the left
          that takes the remaining width, and the control (switch / combo)
          pinned to the right. Applied to the Grid that wraps each row so all
          rows line up consistently regardless of label length.
        -->
        <Style x:Key="SettingRowGrid" TargetType="Grid">
            <Setter Property="Margin" Value="0,6,0,6"/>
        </Style>
        <Style x:Key="SettingLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12" VerticalAlignment="Center">
            <Image Width="60" Height="60" Source="/Resources/Buttons/settings_icon.png" Margin="0,0,12,0"/>
            <StackPanel>
                <TextBlock Text="{DynamicResource Settings_Header}"
                           FontSize="24"
                           FontWeight="Bold"/>
                <TextBlock Text="{DynamicResource Settings_Subtitle}"
                           FontSize="13"
                           Foreground="{DynamicResource MaterialDesignBodyLight}"/>
            </StackPanel>
        </StackPanel>

        <!-- Main content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,0,8">

                <!-- ============================================================
                     Category: Local Data Collection
                     Both switches here keep data on this machine only —
                     nothing here is ever sent anywhere. UI-only for now; will
                     later be bound to the data-collection services (uptime
                     tracker and KeyStatsService). See Settings.xaml.cs for
                     wiring notes.
                     ============================================================ -->
                <materialDesign:Card Margin="0,0,0,12" Padding="12">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Settings_LocalDataCollection}"
                                   FontWeight="Bold"
                                   FontSize="14"
                                   Margin="0,0,0,6"/>

                        <!-- 1. Collect application uptime data -->
                        <Grid Style="{StaticResource SettingRowGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Style="{StaticResource SettingLabel}"
                                       Text="{DynamicResource Settings_CollectUptime}"/>
                            <ToggleButton Grid.Column="1"
                                          x:Name="CollectUptimeToggle"
                                          Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                          Checked="CollectUptimeToggle_Changed"
                                          Unchecked="CollectUptimeToggle_Changed"/>
                        </Grid>

                        <!-- 2. Collect key-press statistics -->
                        <Grid Style="{StaticResource SettingRowGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Style="{StaticResource SettingLabel}"
                                       Text="{DynamicResource Settings_CollectKeyStats}"/>
                            <ToggleButton Grid.Column="1"
                                          x:Name="CollectKeyStatsToggle"
                                          Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                          Checked="CollectKeyStatsToggle_Changed"
                                          Unchecked="CollectKeyStatsToggle_Changed"/>
                        </Grid>
                    </StackPanel>
                </materialDesign:Card>

                <!-- ============================================================
                     Category: Telemetry
                     DRAFT — anonymous product telemetry (opt-in, three tiers:
                     None / Basic / Full). Separate card from Local Data
                     Collection above: this is the sole control that governs
                     anything sent to a server. See TelemetryService's header
                     comment for exactly what each tier sends.
                     ============================================================ -->
                <materialDesign:Card Margin="0,0,0,12" Padding="12">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Settings_TelemetryHeader}"
                                   FontWeight="Bold"
                                   FontSize="14"
                                   Margin="0,0,0,6"/>

                        <Grid Style="{StaticResource SettingRowGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Style="{StaticResource SettingLabel}"
                                       Text="{DynamicResource Settings_CollectTelemetry}"/>
                            <ComboBox Grid.Column="1"
                                      x:Name="TelemetryLevelComboBox"
                                      MinWidth="140"
                                      VerticalAlignment="Center"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      SelectionChanged="TelemetryLevelComboBox_SelectionChanged">
                                <!-- Tag holds the TelemetryLevel enum name the
                                     wiring layer reads; Content is the
                                     user-facing label. Order matches the
                                     ConsentDialog cards (Full, Basic, None). -->
                                <ComboBoxItem Content="{DynamicResource Settings_TelemetryFull}" Tag="Full"/>
                                <ComboBoxItem Content="{DynamicResource Settings_TelemetryBasic}" Tag="Basic"/>
                                <ComboBoxItem Content="{DynamicResource Settings_TelemetryNone}" Tag="None" IsSelected="True"/>
                            </ComboBox>
                        </Grid>
                        <!-- Prominent, tier-independent reassurance — same
                             message and tone as ConsentDialog's keylogger
                             card (not a keylogger + security priority + open
                             source, ending in the same GitHub link), kept
                             visible here too since this is where a returning
                             user reconsiders their choice, not just on first
                             run. -->
                        <TextBlock TextWrapping="Wrap"
                                   Margin="0,2,0,2"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Text="{DynamicResource Settings_TelemetryAssurance}"/>
                        <TextBlock Margin="0,0,0,4">
                            <Hyperlink NavigateUri="https://github.com/Reksaku/ClickyKeys"
                                       RequestNavigate="Hyperlink_RequestNavigate">
                                <Run Text="github.com/Reksaku/ClickyKeys" FontSize="11"/>
                            </Hyperlink>
                        </TextBlock>
                        <!-- Collapsed by default — the assurance text above
                             already covers the important safety point;
                             this is the "read more if you're curious" detail
                             per tier, one paragraph each. -->
                        <Expander Header="{DynamicResource Settings_TelemetryDescHeader}"
                                  FontSize="11"
                                  Margin="0,0,0,0"
                                  IsExpanded="False" Background="White">
                            <StackPanel Margin="0,6,0,0">
                                <TextBlock FontWeight="Bold"
                                           FontSize="11"
                                           Margin="0,0,0,1"
                                           Text="{DynamicResource Settings_TelemetryNone}"/>
                                <TextBlock TextWrapping="Wrap"
                                           FontSize="11"
                                           Margin="0,0,0,6"
                                           Foreground="{DynamicResource MaterialDesignBodyLight}"
                                           Text="{DynamicResource Settings_TelemetryDescNone}"/>

                                <TextBlock FontWeight="Bold"
                                           FontSize="11"
                                           Margin="0,0,0,1"
                                           Text="{DynamicResource Settings_TelemetryBasic}"/>
                                <TextBlock TextWrapping="Wrap"
                                           FontSize="11"
                                           Margin="0,0,0,6"
                                           Foreground="{DynamicResource MaterialDesignBodyLight}"
                                           Text="{DynamicResource Settings_TelemetryDescBasic}"/>

                                <TextBlock FontWeight="Bold"
                                           FontSize="11"
                                           Margin="0,0,0,1"
                                           Text="{DynamicResource Settings_TelemetryFull}"/>
                                <TextBlock TextWrapping="Wrap"
                                           FontSize="11"
                                           Foreground="{DynamicResource MaterialDesignBodyLight}"
                                           Text="{DynamicResource Settings_TelemetryDescFull}"/>
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </materialDesign:Card>

                <!-- ============================================================
                     Category: Usage
                     Autostart and start-minimized are OS-integration toggles;
                     language switching requires reloading localized resources.
                     All are UI-only placeholders for now — see code-behind.
                     ============================================================ -->
                <materialDesign:Card Margin="0,0,0,12" Padding="12">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Settings_Usage}"
                                   FontWeight="Bold"
                                   FontSize="14"
                                   Margin="0,0,0,6"/>

                        <!-- 1. Launch on system startup (autostart) -->
                        <Grid Style="{StaticResource SettingRowGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Style="{StaticResource SettingLabel}"
                                       Text="{DynamicResource Settings_LaunchOnStartup}"/>
                            <ToggleButton Grid.Column="1"
                                          x:Name="AutostartToggle"
                                          Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                          Checked="AutostartToggle_Changed"
                                          Unchecked="AutostartToggle_Changed"/>
                        </Grid>

                        <!-- 2. Start minimized -->
                        <Grid Style="{StaticResource SettingRowGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Style="{StaticResource SettingLabel}"
                                       Text="{DynamicResource Settings_StartMinimized}"/>
                            <ToggleButton Grid.Column="1"
                                          x:Name="StartMinimizedToggle"
                                          Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                          Checked="StartMinimizedToggle_Changed"
                                          Unchecked="StartMinimizedToggle_Changed"/>
                        </Grid>

                        <!-- 3. Language selector -->
                        <Grid Style="{StaticResource SettingRowGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Style="{StaticResource SettingLabel}"
                                       Text="{DynamicResource Settings_Language}"/>
                            <ComboBox Grid.Column="1"
                                      x:Name="LanguageComboBox"
                                      MinWidth="140"
                                      VerticalAlignment="Center"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      SelectionChanged="LanguageComboBox_SelectionChanged">
                                <!-- Tag holds the culture code the wiring layer
                                     will eventually read; Content is the
                                     user-facing label. -->
                                <!-- Languages are listed alphabetically by their
                                     native name. Ελληνικά (Greek) is placed in
                                     the "E" group (Ε ≈ E / "Elliniká"). The Tag
                                     is the culture code read by the wiring layer;
                                     Content is the user-facing native label. -->
                                <ComboBoxItem Content="Deutsch" Tag="de"/>
                                <ComboBoxItem Content="Ελληνικά" Tag="el"/>
                                <ComboBoxItem Content="English" Tag="en" IsSelected="True"/>
                                <ComboBoxItem Content="Español" Tag="es"/>
                                <ComboBoxItem Content="Español (México)" Tag="es-MX"/>
                                <ComboBoxItem Content="Français" Tag="fr"/>
                                <ComboBoxItem Content="Italiano" Tag="it"/>
                                <ComboBoxItem Content="Nederlands" Tag="nl"/>
                                <ComboBoxItem Content="Norsk" Tag="nb"/>
                                <ComboBoxItem Content="Polski" Tag="pl"/>
                                <ComboBoxItem Content="Português" Tag="pt"/>
                                <ComboBoxItem Content="Português (Brasil)" Tag="pt-BR"/>
                                <ComboBoxItem Content="Svenska" Tag="sv"/>
                            </ComboBox>
                        </Grid>
                    </StackPanel>
                </materialDesign:Card>

                <!-- ============================================================
                     Category: Shortcuts
                     Global hotkeys handled by InputCounter. Each button captures
                     the next key the user presses (Esc cancels). Defaults: F12
                     reset, F11 toggle toolbar.
                     ============================================================ -->
                <materialDesign:Card Margin="0,0,0,12" Padding="12">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Settings_Shortcuts}"
                                   FontWeight="Bold"
                                   FontSize="14"
                                   Margin="0,0,0,6"/>

                        <!-- 1. Reset counters -->
                        <Grid Style="{StaticResource SettingRowGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Style="{StaticResource SettingLabel}"
                                       Text="{DynamicResource Settings_ResetShortcut}"/>
                            <Button Grid.Column="1"
                                    x:Name="ResetKeyButton"
                                    MinWidth="150"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Click="ResetKeyButton_Click"
                                    PreviewKeyDown="ShortcutButton_PreviewKeyDown"
                                    LostFocus="ShortcutButton_LostFocus"/>
                        </Grid>

                        <!-- 2. Hide / show toolbar -->
                        <Grid Style="{StaticResource SettingRowGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Style="{StaticResource SettingLabel}"
                                       Text="{DynamicResource Settings_ToggleToolbarShortcut}"/>
                            <Button Grid.Column="1"
                                    x:Name="ToggleToolbarKeyButton"
                                    MinWidth="150"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Click="ToggleToolbarKeyButton_Click"
                                    PreviewKeyDown="ShortcutButton_PreviewKeyDown"
                                    LostFocus="ShortcutButton_LostFocus"/>
                        </Grid>
                    </StackPanel>
                </materialDesign:Card>

                <!-- ============================================================
                     Category: Gamepad
                     ============================================================ -->
                <materialDesign:Card Margin="0,0,0,12" Padding="12">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Settings_Gamepad}"
                                   FontWeight="Bold"
                                   FontSize="14"
                                   Margin="0,0,0,6"/>

                        <!-- LT/RT analog trigger activation threshold (1–100%). -->
                        <Grid Style="{StaticResource SettingRowGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource SettingLabel}">
                                <Run Text="{DynamicResource Settings_TriggerThreshold}"/>
                                <Run Text="{Binding ElementName=TriggerThresholdSlider, Path=Value, StringFormat={}{0:0}}"/><Run Text="%"/>
                            </TextBlock>
                            <Slider Grid.Column="1"
                                    x:Name="TriggerThresholdSlider"
                                    MinWidth="170"
                                    VerticalAlignment="Center"
                                    Minimum="1" Maximum="100"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    Value="25"
                                    ValueChanged="TriggerThresholdSlider_ValueChanged"/>
                        </Grid>
                    </StackPanel>
                </materialDesign:Card>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <DockPanel Grid.Row="2" Margin="0,8,0,0">
            <Button DockPanel.Dock="Right"
                    Width="Auto"
                    Margin="100,0,100,0"
                    Content="{DynamicResource Common_Close}"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    IsCancel="True"
                    Click="Click_Close"/>
        </DockPanel>
    </Grid>
</Window>
