<Window x:Class="ClickyKeys.Settings"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ClickyKeys"
        mc:Ignorable="d"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="ClickyKeys Settings"
        Width="490" Height="780"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Closing="Window_Closed"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.FontFamily="Segoe UI"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12" VerticalAlignment="Center">
            <Image Width="60" Height="60" Source="/Resources/Buttons/settings_icon.png" Margin="0,0,12,0"/>
            <StackPanel>
                <TextBlock Text="Settings"
                           FontSize="24"
                           FontWeight="Bold"/>
                <TextBlock Text="Configure ClickyKeys"
                           FontSize="13"
                           Foreground="{DynamicResource MaterialDesignBodyLight}"/>
            </StackPanel>
        </StackPanel>

        <!-- Main content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,0,8">

                <!-- Placeholder: settings options will be added here. -->
                <materialDesign:Card Margin="0,0,0,12" Padding="12">
                    <StackPanel>
                        <TextBlock Text="General"
                                   FontWeight="Bold"
                                   FontSize="14"
                                   Margin="0,0,0,6"/>
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}">
                            No settings available yet — options will appear here soon.
                        </TextBlock>
                    </StackPanel>
                </materialDesign:Card>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <DockPanel Grid.Row="2" Margin="0,8,0,0">
            <Button DockPanel.Dock="Right"
                    Width="80"
                    Margin="0,0,10,0"
                    Content="Close"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    IsCancel="True"
                    Click="Click_Close"/>
        </DockPanel>
    </Grid>
</Window>
