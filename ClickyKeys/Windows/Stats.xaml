<Window x:Class="ClickyKeys.Stats"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ClickyKeys"
        mc:Ignorable="d"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="{DynamicResource Stats_Title}"
        Width="490" Height="780"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Closing="Window_Closed"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.FontFamily="Segoe UI"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}">

    <Window.Resources>
        <!--
          Shared row template: name on the left, count right-aligned on the
          right. Used by the keys / mouse / wheel ItemsControls below so the
          three lists render consistently.
        -->
        <DataTemplate x:Key="StatRowTemplate">
            <Grid Margin="0,2,0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding Name}"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding CountFormatted}"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"/>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12" VerticalAlignment="Center">
            <Image Width="60" Height="60" Source="/Resources/Icon.ico" Margin="0,0,12,0"/>
            <StackPanel>
                <TextBlock Text="{DynamicResource Stats_Header}"
                           FontSize="24"
                           FontWeight="Bold"/>
                <TextBlock Text="{DynamicResource Stats_Subtitle}"
                           FontSize="13"
                           Foreground="{DynamicResource MaterialDesignBodyLight}"/>
            </StackPanel>
        </StackPanel>

        <!-- Main content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,0,8">

                <!-- Application uptime. Sits at the very top, above the key
                     statistics, and stays visible regardless of the key-stats
                     toggle (it has its own enabled/disabled state). -->
                <materialDesign:Card Margin="0,0,0,12" Padding="12">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Stats_Uptime}"
                                   FontWeight="Bold"
                                   FontSize="14"
                                   Margin="0,0,0,6"/>
                        <TextBlock x:Name="UptimeText"
                                   FontWeight="Bold"
                                   FontSize="20"/>
                        <TextBlock x:Name="UptimeDisabledText"
                                   Text="{DynamicResource Stats_UptimeOff}"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}"
                                   FontStyle="Italic"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Shown instead of the counters when input-statistics
                     collection is turned off in Settings. Visibility is driven
                     from code-behind based on the persisted CollectKeyStats
                     flag. -->
                <materialDesign:Card x:Name="DisabledPanel"
                                     Margin="0,0,0,12"
                                     Padding="16"
                                     Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Stats_CollectionOff}"
                                   FontWeight="Bold"
                                   FontSize="15"
                                   Margin="0,0,0,6"/>
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}">
                            Key-press statistics are not being recorded right now.
                            You can turn collection back on in Settings → Data Collection.
                        </TextBlock>
                    </StackPanel>
                </materialDesign:Card>

                <!-- All the counter cards. Hidden as a group when collection
                     is disabled so only the notice above remains. -->
                <StackPanel x:Name="StatsContentPanel">

                <!-- Totals -->
                <materialDesign:Card Margin="0,0,0,12" Padding="12">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Stats_Totals}"
                                   FontWeight="Bold"
                                   FontSize="14"
                                   Margin="0,0,0,6"/>

                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{DynamicResource Stats_TotalMouseClicks}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       x:Name="TotalMouseClicksText"
                                       FontWeight="Bold"
                                       FontSize="16"
                                       VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{DynamicResource Stats_TotalKeyPresses}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       x:Name="TotalKeyPressesText"
                                       FontWeight="Bold"
                                       FontSize="16"
                                       VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{DynamicResource Stats_TotalWheelTicks}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       x:Name="TotalWheelTicksText"
                                       FontWeight="Bold"
                                       FontSize="16"
                                       VerticalAlignment="Center"/>
                        </Grid>

                        <Separator Margin="0,8,0,8"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{DynamicResource Stats_Combined}"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       x:Name="TotalCombinedText"
                                       FontWeight="Bold"
                                       FontSize="18"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Per-key counts -->
                <materialDesign:Card Margin="0,0,0,12" Padding="12">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Stats_Keys}"
                                   FontWeight="Bold"
                                   FontSize="14"
                                   Margin="0,0,0,6"/>
                        <TextBlock x:Name="KeysEmptyText"
                                   Text="{DynamicResource Stats_NoKeys}"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}"
                                   FontStyle="Italic"
                                   Visibility="Collapsed"/>
                        <ItemsControl x:Name="KeysList"
                                      ItemTemplate="{StaticResource StatRowTemplate}"/>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Per-mouse-button counts -->
                <materialDesign:Card Margin="0,0,0,12" Padding="12">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Stats_MouseButtons}"
                                   FontWeight="Bold"
                                   FontSize="14"
                                   Margin="0,0,0,6"/>
                        <TextBlock x:Name="MouseEmptyText"
                                   Text="{DynamicResource Stats_NoMouse}"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}"
                                   FontStyle="Italic"
                                   Visibility="Collapsed"/>
                        <ItemsControl x:Name="MouseList"
                                      ItemTemplate="{StaticResource StatRowTemplate}"/>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Per-wheel-direction counts -->
                <materialDesign:Card Margin="0,0,0,12" Padding="12">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Stats_MouseWheel}"
                                   FontWeight="Bold"
                                   FontSize="14"
                                   Margin="0,0,0,6"/>
                        <TextBlock x:Name="WheelEmptyText"
                                   Text="{DynamicResource Stats_NoWheel}"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}"
                                   FontStyle="Italic"
                                   Visibility="Collapsed"/>
                        <ItemsControl x:Name="WheelList"
                                      ItemTemplate="{StaticResource StatRowTemplate}"/>
                    </StackPanel>
                </materialDesign:Card>

                </StackPanel>
                <!-- /StatsContentPanel -->

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <DockPanel Grid.Row="2" Margin="0,8,0,0">
            <TextBlock x:Name="LastUpdatedText"
                       DockPanel.Dock="Left"
                       VerticalAlignment="Center"
                       FontSize="11"
                       Foreground="{DynamicResource MaterialDesignBodyLight}"/>
            <Button DockPanel.Dock="Right"
                    Width="80"
                    Margin="150,0,0,0"
                    Content="{DynamicResource Common_Close}"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    IsCancel="True"
                    Click="Click_Close"/>
        </DockPanel>
    </Grid>
</Window>
