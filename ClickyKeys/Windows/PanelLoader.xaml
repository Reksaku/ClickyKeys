<Window x:Class="ClickyKeys.PanelLoader"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ClickyKeys"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:controls="clr-namespace:ClickyKeys.Controls"
        mc:Ignorable="d"
        Closing="Window_Closed"
        Title="{DynamicResource PanelLoader_Title}"
        Height="380"
        Width="360" MinWidth="360" MaxWidth="360"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.FontFamily="Segoe UI"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Icon="/Resources/Icon.ico">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header: icon + title + subtitle, matching SetLoader / Appearance. -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12" VerticalAlignment="Top">
            <Image Width="60" Height="60" Source="/Resources/Buttons/appearance_icon.png" Margin="0,-5,12,0"/>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="{DynamicResource PanelLoader_Title}"
                           FontSize="24"
                           FontWeight="Bold"/>
                <TextBlock Text="{DynamicResource SetLoader_SelectProfile}"
                           FontSize="13"
                           Foreground="{DynamicResource MaterialDesignBodyLight}"/>
            </StackPanel>
        </StackPanel>

        <!-- All profiles live in a single Card "segment", like SetLoader. -->
        <materialDesign:Card Grid.Row="1" Margin="0,0,0,12" Padding="12">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <Grid x:Name="filesList"/>
            </ScrollViewer>
        </materialDesign:Card>

        <!-- Footer: right-docked MaterialDesign buttons. -->
        <DockPanel Grid.Row="2" Margin="0,8,0,0" LastChildFill="False">
            <Button DockPanel.Dock="Right"
                    Margin="8,0,0,0"
                    Content="{DynamicResource Common_Exit}"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    IsCancel="True"
                    Click="Click_Exit"/>
            <Button DockPanel.Dock="Right"
                    Margin="8,0,0,0"
                    Content="{DynamicResource Common_Load}"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Click="Click_Load"/>
        </DockPanel>
    </Grid>
</Window>
