<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Class="ClickyKeys.TutorialWindow"
    Title="{DynamicResource Tutorial_Title}"
    WindowStyle="None"
    AllowsTransparency="True"
    Background="Transparent"
    ShowInTaskbar="False"
    Topmost="True"
    ResizeMode="NoResize"
    SizeToContent="WidthAndHeight"
    IsHitTestVisible="True">

    <!--
        Floating tutorial card — no full-screen overlay so the user can
        interact with the main window panels at any point during the tutorial.
        The card positions itself near the highlighted element via code-behind.
    -->

    <Border x:Name="CardBorder"
            Background="White"
            CornerRadius="10"
            Padding="18,14"
            MinWidth="340"
            Margin="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18" ShadowDepth="3"
                              Opacity="0.28" Color="Black"/>
        </Border.Effect>

        <StackPanel>

            <!-- Step indicator -->
            <TextBlock x:Name="StepIndicator"
                       FontSize="11"
                       Foreground="#888"
                       HorizontalAlignment="Right"
                       Margin="0,0,0,4"/>

            <!-- Optional title -->
            <TextBlock x:Name="TitleText"
                       FontSize="14"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap"
                       MaxWidth="300"
                       HorizontalAlignment="Left"
                       Margin="0,0,0,6"
                       Visibility="Collapsed"/>

            <!-- Body copy -->
            <TextBlock x:Name="BodyText"
                       FontSize="12"
                       TextWrapping="Wrap"
                       LineHeight="18"
                       MaxWidth="300"
                       HorizontalAlignment="Left"
                       Margin="0,0,0,12"/>

            <!-- Arrow hint — shown when pointing at a specific element -->
            <TextBlock x:Name="ArrowHint"
                       FontSize="11"
                       Foreground="#1976D2"
                       FontStyle="Italic"
                       TextWrapping="Wrap"
                       MaxWidth="300"
                       HorizontalAlignment="Left"
                       Margin="0,0,0,10"
                       Visibility="Collapsed"/>

            <!-- Shown when a gated step's required action has been completed -->
            <TextBlock x:Name="GateDoneText"
                       Text="{DynamicResource Tutorial_ActionDone}"
                       FontSize="11"
                       Foreground="#2E7D32"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap"
                       MaxWidth="300"
                       HorizontalAlignment="Left"
                       Margin="0,0,0,10"
                       Visibility="Collapsed"/>

            <!-- Progress bar -->
            <ProgressBar x:Name="ProgressBar"
                         Height="3"
                         Minimum="0"
                         Margin="0,0,0,12"
                         Foreground="#1976D2"
                         Background="#E0E0E0"/>

            <!-- Navigation — single row, right-aligned. The card (and window)
                 auto-size to content, so in languages with long button labels
                 the whole window widens instead of wrapping or clipping. -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button x:Name="SkipBtn"
                        Content="{DynamicResource Tutorial_Skip}"
                        Padding="10,4"
                        Margin="0,0,8,0"
                        Click="Skip_Click"
                        Foreground="#888"/>
                <Button x:Name="SkipStepBtn"
                        Content="{DynamicResource Tutorial_SkipStep}"
                        Padding="10,4"
                        Margin="0,0,8,0"
                        Click="SkipStep_Click"
                        Foreground="#888"
                        Visibility="Collapsed"/>
                <Button x:Name="BackBtn"
                        Content="{DynamicResource Tutorial_Back}"
                        Padding="10,4"
                        Margin="0,0,8,0"
                        Click="Back_Click"
                        Visibility="Collapsed"/>
                <Button x:Name="NextBtn"
                        Content="{DynamicResource Tutorial_Next}"
                        Padding="10,4"
                        Click="Next_Click"/>
            </StackPanel>

        </StackPanel>
    </Border>
</Window>
