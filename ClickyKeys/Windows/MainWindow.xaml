<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:tb="http://www.hardcodet.net/taskbar"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:local="clr-namespace:ClickyKeys"
    x:Class="ClickyKeys.MainWindow"
    Title="ClickyKeys"
    Width="Auto" Height="Auto" SizeToContent="WidthAndHeight"
    ResizeMode="CanMinimize"
    WindowStyle="SingleBorderWindow"
    Closing="Window_Closed"
    StateChanged="Window_StateChanged"
    Activated="Window_Activated"
    Icon="/Resources/Icon.ico">

    <Window.Resources>

        <!--
          Tray icon is created in code-behind (InitTrayIcon) so it can be
          shared across the window lifecycle without relying on lazy XAML
          resource resolution.
        -->

        <!--
          Converter: horizontal StackPanel (icon beside text) -> right margin;
          vertical (icon above text) -> bottom margin.
          Requires OrientationToMarginConverter class in code-behind.
        -->
        <local:OrientationToMarginConverter x:Key="OrientationToMarginConverter"/>

        <!--
          Converter: horizontal (icon beside text) -> size 30;
          vertical (icon above text) -> size 20.
          Requires OrientationToSizeConverter class in code-behind.
        -->
        <local:OrientationToSizeConverter x:Key="OrientationToSizeConverter"/>

        <!-- Preserved original toolbar solution with UniformGrid -->
        <Style TargetType="ToolBar">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolBar">
                        <Border Padding="2">
                            <UniformGrid IsItemsHost="True" Rows="1"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Window.Style>
        <StaticResource ResourceKey="MaterialDesignWindow"/>
    </Window.Style>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="305*"/>
            <ColumnDefinition Width="177*"/>
        </Grid.ColumnDefinitions>

        <DockPanel LastChildFill="True" Background="{Binding Background}" Grid.ColumnSpan="2">

            <!--
                ToolBar – buttons with icon and label.
                StackPanel orientation (vertical/horizontal) is controlled by
                the ButtonOrientation property in code-behind,
                updated whenever the myGrid row count changes.
            -->
            <ToolBar DockPanel.Dock="Top" Height="68"
                     FontSize="13"
                     ScrollViewer.CanContentScroll="True"
                     x:Name="ToolStrip">

                <Button Click="Appearance_Click" x:Name="Appearance_Button"
                        Padding="4,2"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch">
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Orientation="{Binding ButtonOrientation,
                                    RelativeSource={RelativeSource AncestorType=Window}}">
                        <Image Source="/Resources/Buttons/appearance_icon.png"
                               Width="{Binding ButtonOrientation, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource OrientationToSizeConverter}}"
                               Height="{Binding ButtonOrientation, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource OrientationToSizeConverter}}"
                               Margin="{Binding ButtonOrientation,
                                   RelativeSource={RelativeSource AncestorType=Window},
                                   Converter={StaticResource OrientationToMarginConverter}}"/>
                        <TextBlock Text="{DynamicResource Main_Appearance}" FontSize="13"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{Binding ToolbarTextColor, RelativeSource={RelativeSource AncestorType=Window}}"/>
                    </StackPanel>
                </Button>

                <Button x:Name="Display_Button"
                        Padding="4,2"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        MouseEnter="Display_Button_MouseEnter"
                        MouseLeave="Display_Button_MouseLeave">
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Orientation="{Binding ButtonOrientation,
                                    RelativeSource={RelativeSource AncestorType=Window}}">
                        <Image Source="/Resources/Buttons/display_icon.png"
                               Width="{Binding ButtonOrientation, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource OrientationToSizeConverter}}"
                               Height="{Binding ButtonOrientation, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource OrientationToSizeConverter}}"
                               Margin="{Binding ButtonOrientation,
                                   RelativeSource={RelativeSource AncestorType=Window},
                                   Converter={StaticResource OrientationToMarginConverter}}"/>
                        <TextBlock Text="{DynamicResource Main_Display}" FontSize="13"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{Binding ToolbarTextColor, RelativeSource={RelativeSource AncestorType=Window}}"/>
                    </StackPanel>
                </Button>

                <Button Click="Reset_Click" x:Name="Reset_Button"
                        Padding="4,2"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch">
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Orientation="{Binding ButtonOrientation,
                                    RelativeSource={RelativeSource AncestorType=Window}}">
                        <Image Source="/Resources/Buttons/reset_icon.png"
                               Width="{Binding ButtonOrientation, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource OrientationToSizeConverter}}"
                               Height="{Binding ButtonOrientation, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource OrientationToSizeConverter}}"
                               Margin="{Binding ButtonOrientation,
                                   RelativeSource={RelativeSource AncestorType=Window},
                                   Converter={StaticResource OrientationToMarginConverter}}"/>
                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="{DynamicResource Main_Reset}" FontSize="13" HorizontalAlignment="Center"
                                       Foreground="{Binding ToolbarTextColor, RelativeSource={RelativeSource AncestorType=Window}}"/>
                            <TextBlock Text="{Binding ResetKeyLabel, RelativeSource={RelativeSource AncestorType=Window}}" FontSize="13" HorizontalAlignment="Center"
                                       Foreground="{Binding ToolbarTextColor, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        </StackPanel>
                    </StackPanel>
                </Button>

                <Button Click="Stats_Click" x:Name="Stats_Button"
                        Padding="4,2"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch">
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Orientation="{Binding ButtonOrientation,
                                    RelativeSource={RelativeSource AncestorType=Window}}">
                        <Image Source="/Resources/Buttons/stats_icon.png"
                               Width="{Binding ButtonOrientation, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource OrientationToSizeConverter}}"
                               Height="{Binding ButtonOrientation, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource OrientationToSizeConverter}}"
                               Margin="{Binding ButtonOrientation,
                                   RelativeSource={RelativeSource AncestorType=Window},
                                   Converter={StaticResource OrientationToMarginConverter}}"/>
                        <TextBlock Text="{DynamicResource Main_Stats}" FontSize="13"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{Binding ToolbarTextColor, RelativeSource={RelativeSource AncestorType=Window}}"/>
                    </StackPanel>
                </Button>

                <Button x:Name="More_Button"
                        Padding="4,2"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        MouseEnter="More_Button_MouseEnter"
                        MouseLeave="More_Button_MouseLeave">
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Orientation="{Binding ButtonOrientation,
                                    RelativeSource={RelativeSource AncestorType=Window}}">
                        <!-- Icon wrapped in a Grid so the unread badge can
                             overlay it, mirroring the Messages button badge.
                             Shown by RefreshMessagesBadge when a new message
                             has been received. -->
                        <Grid Margin="{Binding ButtonOrientation,
                                   RelativeSource={RelativeSource AncestorType=Window},
                                   Converter={StaticResource OrientationToMarginConverter}}">
                            <Image Source="/Resources/Buttons/more_icon.png"
                                   Width="{Binding ButtonOrientation, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource OrientationToSizeConverter}}"
                                   Height="{Binding ButtonOrientation, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource OrientationToSizeConverter}}"/>
                            <Border x:Name="MoreBadge"
                                    Visibility="Collapsed"
                                    Background="#F44336"
                                    CornerRadius="8"
                                    MinWidth="16" Height="16"
                                    Padding="3,0"
                                    HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Margin="0,-4,-6,0">
                                <TextBlock x:Name="MoreBadgeText"
                                           Text="0"
                                           FontSize="10" FontWeight="Bold"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <TextBlock Text="{DynamicResource Main_More}" FontSize="13"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{Binding ToolbarTextColor, RelativeSource={RelativeSource AncestorType=Window}}"/>
                    </StackPanel>
                </Button>

            </ToolBar>



            <Popup x:Name="DisplayPopup"
                   PlacementTarget="{Binding ElementName=Display_Button}"
                   Placement="Bottom"
                   StaysOpen="True"
                   AllowsTransparency="True"
                   PopupAnimation="Slide">
                <Border x:Name="DisplayPopupBorder"
                        Padding="2"
                        MinWidth="{Binding ActualWidth, ElementName=Display_Button}"
                        CornerRadius="0,0,8,8"
                        BorderBrush="{DynamicResource MaterialDesignDivider}"
                        BorderThickness="2,0,2,2"
                        MouseEnter="DisplayPopup_MouseEnter"
                        MouseLeave="DisplayPopup_MouseLeave"
                        Background="{Binding Background}">
                    <StackPanel Orientation="Vertical">
                        <Button Click="TransparentMode_Click" x:Name="TransparentMode_Button"
                                Style="{DynamicResource {x:Static ToolBar.ButtonStyleKey}}"
                                HorizontalAlignment="Stretch"
                                Padding="4,2" Height="68">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Orientation="Vertical">
                                <Image Source="/Resources/Buttons/transparent_icon.png"
                                       Width="28" Height="28" Margin="0,0,0,2"/>
                                <TextBlock Text="{DynamicResource Main_Transparent}" FontSize="13" HorizontalAlignment="Center"
                                           Foreground="{Binding ToolbarTextColor}"/>
                                <TextBlock Text="{DynamicResource Main_Mode}" FontSize="13" HorizontalAlignment="Center"
                                           Foreground="{Binding ToolbarTextColor}"/>
                            </StackPanel>
                        </Button>
                        <Button Click="ToggleToolbar_Click" x:Name="ToggleToolbar_Button"
                                Style="{DynamicResource {x:Static ToolBar.ButtonStyleKey}}"
                                HorizontalAlignment="Stretch"
                                Padding="4,2" Height="68">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Orientation="Vertical">
                                <Image Source="/Resources/Buttons/hide_toolbar_icon.png"
                                       Width="28" Height="28" Margin="0,0,0,2"/>
                                <TextBlock Text="{DynamicResource Main_HideToolbar}" FontSize="13" HorizontalAlignment="Center"
                                           Foreground="{Binding ToolbarTextColor}"/>
                                <TextBlock Text="{Binding ToggleToolbarKeyLabel}" FontSize="13" HorizontalAlignment="Center"
                                           Foreground="{Binding ToolbarTextColor}"/>
                            </StackPanel>
                        </Button>
                        <Button Click="AlwaysOnTop_Click" x:Name="AlwaysOnTop_Button"
                                Style="{DynamicResource {x:Static ToolBar.ButtonStyleKey}}"
                                HorizontalAlignment="Stretch"
                                Padding="4,2" Height="68">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Orientation="Vertical">
                                <Image Source="/Resources/Buttons/display_icon.png"
                                       Width="28" Height="28" Margin="0,0,0,2"/>
                                <TextBlock Text="{DynamicResource Main_AlwaysOnTop}" FontSize="13"
                                           HorizontalAlignment="Center" TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           Foreground="{Binding ToolbarTextColor}"/>
                                <TextBlock x:Name="AlwaysOnTopStateText"
                                           Text="{DynamicResource Main_Off}" FontSize="13"
                                           HorizontalAlignment="Center"
                                           Foreground="{Binding ToolbarTextColor}"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </Popup>


            <Popup x:Name="MorePopup"
                   PlacementTarget="{Binding ElementName=More_Button}"
                   Placement="Bottom"
                   StaysOpen="True"
                   AllowsTransparency="True"
                   PopupAnimation="Slide">
                <Border x:Name="MorePopupBorder"
                        Padding="2"
                        MinWidth="{Binding ActualWidth, ElementName=More_Button}"
                        CornerRadius="0,0,8,8"
                        BorderBrush="{DynamicResource MaterialDesignDivider}"
                        BorderThickness="2,0,2,2"
                        MouseEnter="MorePopup_MouseEnter"
                        MouseLeave="MorePopup_MouseLeave"
                        Background="{Binding Background}">
                    <StackPanel Orientation="Vertical">
                        <Button Click="Messages_Click" x:Name="Messages_Button"
                                Style="{DynamicResource {x:Static ToolBar.ButtonStyleKey}}"
                                HorizontalAlignment="Stretch"
                                Padding="4,2" Height="68">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Orientation="Vertical">
                                <Grid Width="28" Height="28" Margin="0,0,0,2">
                                    <Image Source="/Resources/Buttons/messages_icon.png"
                                           Width="28" Height="28"/>
                                    <Border x:Name="MessagesBadge"
                                            Visibility="Collapsed"
                                            Background="#F44336"
                                            CornerRadius="8"
                                            MinWidth="16" Height="16"
                                            Padding="3,0"
                                            HorizontalAlignment="Right" VerticalAlignment="Top"
                                            Margin="0,-4,-6,0">
                                        <TextBlock x:Name="MessagesBadgeText"
                                                   Text="0"
                                                   FontSize="10" FontWeight="Bold"
                                                   Foreground="White"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                                <TextBlock Text="{DynamicResource Main_Messages}" FontSize="13"
                                           HorizontalAlignment="Center"
                                           Foreground="{Binding ToolbarTextColor}"/>
                            </StackPanel>
                        </Button>
                        <Button Click="Info_Click" x:Name="Info_Button"
                                Style="{DynamicResource {x:Static ToolBar.ButtonStyleKey}}"
                                HorizontalAlignment="Stretch"
                                Padding="4,2" Height="68">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Orientation="Vertical">
                                <Image Source="/Resources/Buttons/info_icon.png"
                                       Width="28" Height="28" Margin="0,0,0,2"/>
                                <TextBlock Text="{DynamicResource Main_Info}" FontSize="13" HorizontalAlignment="Center"
                                           Foreground="{Binding ToolbarTextColor}"/>
                            </StackPanel>
                        </Button>
                        <Button Click="Settings_Click" x:Name="Settings_Button"
                                Style="{DynamicResource {x:Static ToolBar.ButtonStyleKey}}"
                                HorizontalAlignment="Stretch"
                                Padding="4,2" Height="68">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Orientation="Vertical">
                                <Image Source="/Resources/Buttons/settings_icon.png"
                                       Width="28" Height="28" Margin="0,0,0,2"/>
                                <TextBlock Text="{DynamicResource Main_Settings}" FontSize="13" HorizontalAlignment="Center"
                                           Foreground="{Binding ToolbarTextColor}"/>
                            </StackPanel>
                        </Button>
                        <!-- Uses the Info icon temporarily until a dedicated
                             "Buy Me a Coffee" icon is added. -->
                        <Button Click="BuyMeACoffee_Click" x:Name="BuyMeACoffee_Button"
                                Style="{DynamicResource {x:Static ToolBar.ButtonStyleKey}}"
                                HorizontalAlignment="Stretch"
                                Padding="4,2" Height="68">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Orientation="Vertical">
                                <Image Source="/Resources/Buttons/coffee_icon.png"
                                       Width="28" Height="28" Margin="0,0,0,2"/>
                                <TextBlock Text="{DynamicResource Main_BuyMeACoffee}" FontSize="13"
                                           HorizontalAlignment="Center" TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           Foreground="{Binding ToolbarTextColor}"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </Popup>

            <Grid x:Name="myGrid">
                <Grid.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform/>
                        <SkewTransform/>
                        <RotateTransform/>
                        <TranslateTransform/>
                    </TransformGroup>
                </Grid.RenderTransform>

                <Grid.RowDefinitions>
                    <RowDefinition Height="100"/>
                    <RowDefinition Height="100"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>
            </Grid>

            <Popup x:Name="MyPopup"
                   Placement="Center"
                   PlacementTarget="{Binding ElementName=myGrid}"
                   StaysOpen="False"
                   AllowsTransparency="True"
                   PopupAnimation="Fade">
                <materialDesign:Card x:Name="PopupBorder"
                                     Width="300"
                                     Margin="8"
                                     Padding="16"
                                     UniformCornerRadius="8"
                                     Background="{DynamicResource MaterialDesignPaper}"
                                     TextElement.Foreground="{DynamicResource MaterialDesignBody}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Margin="0,0,0,12">
                            <Image Width="28" Height="28" Margin="0,0,8,0"
                                   Source="/Resources/Icon.ico"/>
                            <TextBlock Text="{DynamicResource Main_UpdateAvailable}"
                                       FontSize="15"
                                       FontWeight="Bold"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center"
                                       MaxWidth="220"/>
                        </StackPanel>
                        <Button Content="{DynamicResource Main_OpenDownload}"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Click="OpenLink_Click"
                                Margin="0,4,0,0"/>
                        <Button Content="{DynamicResource Common_Close}"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Click="ClosePopup_Click"
                                Margin="0,4,0,0"/>
                    </StackPanel>
                </materialDesign:Card>
            </Popup>

            <!-- Shown when the sponsoring URL can't be fetched (no internet). -->
            <Popup x:Name="NoInternetPopup"
                   Placement="Center"
                   PlacementTarget="{Binding ElementName=myGrid}"
                   StaysOpen="False"
                   AllowsTransparency="True"
                   PopupAnimation="Fade">
                <Border Background="White" Padding="20" CornerRadius="8">
                    <StackPanel Width="250">
                        <TextBlock Text="{DynamicResource Main_NoInternet}"
                                   FontSize="14"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Margin="0 0 0 10"/>
                        <Button Content="{DynamicResource Common_Close}"
                                Padding="5"
                                Click="CloseNoInternetPopup_Click"
                                Margin="0 5 0 0"/>
                    </StackPanel>
                </Border>
            </Popup>

        </DockPanel>

    </Grid>
</Window>
