<Window x:Class="ClickyKeys.Info"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ClickyKeys"
        mc:Ignorable="d"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="{DynamicResource Info_Title}"
        Width="490" Height="780"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Closing="Window_Closed"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.FontFamily="Segoe UI"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12" VerticalAlignment="Center">
            <Image Width="60" Height="60" Source="/Resources/Icon.ico" Margin="0,0,12,0"/>
            <StackPanel>
                <TextBlock Text="ClickyKeys"
                           FontSize="24"
                           FontWeight="Bold"/>
                <TextBlock Text="{DynamicResource Info_Tagline}"
                           FontSize="13"
                           Foreground="{DynamicResource MaterialDesignBodyLight}"/>
            </StackPanel>
        </StackPanel>

        <!-- Main content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,0,8">

                <!-- Features -->
                <materialDesign:Card Margin="0,0,0,12" Padding="12">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Info_Features}"
                                   FontWeight="Bold"
                                   FontSize="14"
                                   Margin="0,0,0,6"/>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,4" Text="{DynamicResource Info_Feature1}"/>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,4" Text="{DynamicResource Info_Feature2}"/>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,4" Text="{DynamicResource Info_Feature3}"/>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Privacy & Open Source -->
                <materialDesign:Card Margin="0,0,0,12" Padding="12">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Info_Privacy}"
                                   FontWeight="Bold"
                                   FontSize="14"
                                   Margin="0,0,0,6"/>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,4" Text="{DynamicResource Info_PrivacyText1}"/>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,4" Text="{DynamicResource Info_PrivacyText2}"/>
                    </StackPanel>
                </materialDesign:Card>




                <!-- Credits & Thanks -->
                <materialDesign:Card Margin="0,0,0,12" Padding="12">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Info_Credits}"
                                   FontWeight="Bold"
                                   FontSize="14"
                                   Margin="0,0,0,6"/>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,4" Text="{DynamicResource Info_CreditsText1}"/>
                        <TextBlock TextWrapping="Wrap"
                                   Margin="0,8,0,0"
                                   FontStyle="Italic" Text="{DynamicResource Info_CreditsText2}"/>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Links -->
                <materialDesign:Card Margin="0,0,0,12" Padding="12">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Info_Links}"
                                   FontWeight="Bold"
                                   FontSize="14"
                                   Margin="0,0,0,6"/>

                        <TextBlock Margin="0,0,0,4"><Run Text="{DynamicResource Info_WebsiteLabel}"/>
                            <Hyperlink NavigateUri="https://clickykeys.fun/about"
                                       RequestNavigate="Hyperlink_RequestNavigate">
                                https://clickykeys.fun
                            </Hyperlink>
                        </TextBlock>
                        <TextBlock Margin="0,0,0,4"><Run Text="{DynamicResource Info_GitHubLabel}"/>
                            <Hyperlink NavigateUri="https://github.com/Reksaku/ClickyKeys"
                                       RequestNavigate="Hyperlink_RequestNavigate">
                                github.com/Reksaku/ClickyKeys
                            </Hyperlink>
                        </TextBlock>

                    </StackPanel>
                </materialDesign:Card>

                <!-- Contact -->
                <materialDesign:Card Margin="0,0,0,12" Padding="12">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Info_Contact}"
                                   FontWeight="Bold"
                                   FontSize="14"
                                   Margin="0,0,0,6"/>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,4" Text="{DynamicResource Info_ContactText1}"/>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,4" Text="{DynamicResource Info_ContactText2}"/>
                    </StackPanel>
                </materialDesign:Card>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <DockPanel Grid.Row="2" Margin="0,8,0,0">
            <TextBlock x:Name="textBoxVersion"
                       DockPanel.Dock="Left"
                       VerticalAlignment="Center"
                       FontSize="11"
                       Foreground="{DynamicResource MaterialDesignBodyLight}">
                ClickyKeys · hobby project · v2.2.0
            </TextBlock>
            <Button DockPanel.Dock="Right"
                    Width="80"
                    Margin="0,0,10,0"
                    Content="{DynamicResource Common_Close}"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    IsCancel="True"
                    Click="Click_Close"/>
            <Button DockPanel.Dock="Right"
                    Margin="50,0,8,0"
                    Width="120"
                    Padding="10,0"
                    Content="{DynamicResource Info_ShowTutorial}"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Click="Click_ShowTutorial"/>
        </DockPanel>
    </Grid>
</Window>
