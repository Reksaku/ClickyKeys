<Window x:Class="ClickyKeys.Inbox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ClickyKeys"
        mc:Ignorable="d"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="{DynamicResource Inbox_Title}"
        Width="520"
        MinWidth="400"
        MaxHeight="640"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Closing="Window_Closed"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.FontFamily="Segoe UI"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12" VerticalAlignment="Center">
            <Image Width="48" Height="48" Source="/Resources/Icon.ico" Margin="0,0,12,0"/>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="{DynamicResource Inbox_Header}"
                           FontSize="22"
                           FontWeight="Bold"/>
                <TextBlock x:Name="SubtitleText"
                           FontSize="12"
                           Foreground="{DynamicResource MaterialDesignBodyLight}"/>
            </StackPanel>
        </StackPanel>

        <!-- Content area — switches between the empty notice and the list -->
        <Grid Grid.Row="1">

            <!-- Empty state -->
            <StackPanel x:Name="EmptyPanel"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Visibility="Collapsed">
                <TextBlock Text="{DynamicResource Inbox_Empty}"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Foreground="{DynamicResource MaterialDesignBodyLight}"
                           MaxWidth="360"/>
            </StackPanel>

            <!-- Messages list -->
            <ScrollViewer x:Name="ContentScroller"
                          VerticalScrollBarVisibility="Auto"
                          Visibility="Collapsed">
                <StackPanel x:Name="EntriesPanel" Margin="0,0,4,0"/>
            </ScrollViewer>

        </Grid>

        <!-- Footer -->
        <DockPanel Grid.Row="2" Margin="0,10,0,0">
            <Button DockPanel.Dock="Right"
                    Width="80"
                    Content="{DynamicResource Common_Close}"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    IsCancel="True"
                    Click="Click_Close"/>
        </DockPanel>
    </Grid>
</Window>
