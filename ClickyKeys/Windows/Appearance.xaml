<Window
    x:Class="ClickyKeys.Appearance"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:ClickyKeys"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:controls="clr-namespace:ClickyKeys.Controls"
    mc:Ignorable="d"
    Closing="Window_Closed"
    Title="{DynamicResource Appearance_Title}"
    Width="510" 
    SizeToContent="Height"
    MaxHeight="1035"
    WindowStartupLocation="CenterOwner"
    Background="{DynamicResource MaterialDesignPaper}"
    TextElement.FontFamily="Segoe UI"
    TextElement.Foreground="{DynamicResource MaterialDesignBody}"
    Icon="/Resources/Icon.ico">

    <Window.Resources>
        <!-- Placeholder text box used by the "Save as" popup. -->
        <Style x:Key="PlaceholderTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="4,2,4,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <ScrollViewer x:Name="PART_ContentHost"
                                  Margin="{TemplateBinding Padding}"
                                  VerticalAlignment="Center"/>
                            <TextBlock x:Name="Placeholder"
                               Text="{TemplateBinding Tag}"
                               Margin="{TemplateBinding Padding}"
                               Foreground="Gray"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False"
                               Visibility="Collapsed"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="Placeholder"
                                Property="Visibility"
                                Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Shared row + label layout, matching the Settings window. -->
        <Style x:Key="SettingRowGrid" TargetType="Grid">
            <Setter Property="Margin" Value="0,6,0,6"/>
        </Style>
        <Style x:Key="SettingLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>
        <Style x:Key="CardHeader" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="344*"/>
            <ColumnDefinition Width="109*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Auto (not *) so the window can shrink-wrap the content height
                 under SizeToContent; the ScrollViewer below caps tall content. -->
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Top" Grid.ColumnSpan="2">
            <Image Width="60" Height="60" Source="/Resources/Buttons/appearance_icon.png" Margin="0,-5,12,0"/>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="{DynamicResource Appearance_Title}"
                           FontSize="24"
                           FontWeight="Bold"/>
                <!-- ProfilesLabel still receives its text from code-behind
                     (it sets .Content). Styled to look like the subtitle used
                     in the Settings / Info windows. -->
                <Label x:Name="ProfilesLabel"
                       Content="{DynamicResource Appearance_Profile}"
                       Padding="0"
                       FontSize="13"
                       Foreground="{DynamicResource MaterialDesignBodyLight}"/>
            </StackPanel>
        </StackPanel>

        <!-- Main content. MaxHeight caps how tall the window grows: below it the
             window shrink-wraps the expanded panels; above it the content
             scrolls here instead of pushing the window off-screen. -->
        <ScrollViewer x:Name="ContentScroller"
                      Grid.Row="1" VerticalScrollBarVisibility="Auto" Grid.ColumnSpan="2"
                      MaxHeight="820"
                      ScrollChanged="ContentScroller_ScrollChanged">
            <!-- Right margin keeps a 5px gap between the cards and the
                 vertical scrollbar. -->
            <StackPanel Margin="0,10,5,8">

                <!-- ===================== Grid size ===================== -->
                <materialDesign:Card Margin="0,0,0,12" Padding="12">
                    <Expander IsExpanded="True" Background="Transparent" Padding="0">
                        <Expander.Header>
                            <StackPanel>
                                <TextBlock Style="{StaticResource CardHeader}" Margin="0"
                                           Text="{DynamicResource Appearance_PanelsProfile}"/>
                                <TextBlock Text="{DynamicResource Appearance_PanelsProfileDesc}"
                                           FontSize="12" Margin="0,2,0,0" TextWrapping="Wrap"
                                           Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                            </StackPanel>
                        </Expander.Header>
                        <StackPanel Margin="0,8,0,0">

                        <Label x:Name="PanelsProfilesLabel"
                           Content="{DynamicResource Appearance_Profile}"
                           Padding="0"
                           FontSize="13"
                           Foreground="{DynamicResource MaterialDesignBodyLight}"/>

                        <DockPanel Grid.Row="2" Margin="0,8,0,0" LastChildFill="False" Grid.ColumnSpan="2">

                            <Button x:Name="PanelsProfile_SaveAsButton"
                                DockPanel.Dock="Right"
                                Margin="8,0,0,0"
                                Content="{DynamicResource Common_SaveAs}"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Click="Click_SaveAsPanelsProfile"/>
                            <Button DockPanel.Dock="Right"
                                Margin="8,0,0,0"
                                Content="{DynamicResource Common_Load}"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Click="Click_LoadPanelsProfile"/>
                        </DockPanel>

                        </StackPanel>
                    </Expander>
                </materialDesign:Card>


                <!-- ===================== Grid size ===================== -->
                <materialDesign:Card Margin="0,0,0,12" Padding="12">
                    <Expander IsExpanded="False" Background="Transparent" Padding="0">
                        <Expander.Header>
                            <StackPanel>
                                <TextBlock Style="{StaticResource CardHeader}" Margin="0"
                                           Text="{DynamicResource Appearance_GridSize}"/>
                                <TextBlock Text="{DynamicResource Appearance_GridSizeDesc}"
                                           FontSize="12" Margin="0,2,0,0" TextWrapping="Wrap"
                                           Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                            </StackPanel>
                        </Expander.Header>
                        <StackPanel Margin="0,8,0,0">

                        <Grid Style="{StaticResource SettingRowGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Style="{StaticResource SettingLabel}"
                                       Text="{DynamicResource Appearance_GridRows}"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <materialDesign:DecimalUpDown x:Name="RowsCount"
                                                              Width="90" Minimum="1" Maximum="10"
                                                              FontSize="15" VerticalAlignment="Center"/>
                                <Button Content="{DynamicResource Common_Set}"
                                        Margin="8,0,0,0" VerticalAlignment="Center"
                                        Style="{StaticResource MaterialDesignFlatButton}"
                                        Click="Click_GridRows"/>
                            </StackPanel>
                        </Grid>

                        <Grid Style="{StaticResource SettingRowGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Style="{StaticResource SettingLabel}"
                                       Text="{DynamicResource Appearance_GridColumns}"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <materialDesign:DecimalUpDown x:Name="ColumnsCount"
                                                              Width="90" Minimum="1" Maximum="10"
                                                              FontSize="15" VerticalAlignment="Center"/>
                                <Button Content="{DynamicResource Common_Set}"
                                        Margin="8,0,0,0" VerticalAlignment="Center"
                                        Style="{StaticResource MaterialDesignFlatButton}"
                                        Click="Click_GridColumns"/>
                            </StackPanel>
                        </Grid>

                        <Grid Style="{StaticResource SettingRowGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Style="{StaticResource SettingLabel}"
                                       Text="{DynamicResource Appearance_PanelWidth}"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <materialDesign:DecimalUpDown x:Name="PanelWidthCount"
                                                              Width="90" Minimum="40" Maximum="600"
                                                              FontSize="15" VerticalAlignment="Center"/>
                                <Button Content="{DynamicResource Common_Set}"
                                        Margin="8,0,0,0" VerticalAlignment="Center"
                                        Style="{StaticResource MaterialDesignFlatButton}"
                                        Click="Click_PanelWidth"/>
                            </StackPanel>
                        </Grid>

                        <Grid Style="{StaticResource SettingRowGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Style="{StaticResource SettingLabel}"
                                       Text="{DynamicResource Appearance_PanelHeight}"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <materialDesign:DecimalUpDown x:Name="PanelHeightCount"
                                                              Width="90" Minimum="30" Maximum="400"
                                                              FontSize="15" VerticalAlignment="Center"/>
                                <Button Content="{DynamicResource Common_Set}"
                                        Margin="8,0,0,0" VerticalAlignment="Center"
                                        Style="{StaticResource MaterialDesignFlatButton}"
                                        Click="Click_PanelHeight"/>
                            </StackPanel>
                        </Grid>
                        </StackPanel>
                    </Expander>
                </materialDesign:Card>

                <!-- ===================== Colors ===================== -->
                <materialDesign:Card Margin="0,0,0,12" Padding="12">
                    <Expander IsExpanded="False" Background="Transparent" Padding="0">
                        <Expander.Header>
                            <StackPanel>
                                <TextBlock Style="{StaticResource CardHeader}" Margin="0"
                                           Text="{DynamicResource Appearance_Colors}"/>
                                <TextBlock Text="{DynamicResource Appearance_ColorsDesc}"
                                           FontSize="12" Margin="0,2,0,0" TextWrapping="Wrap"
                                           Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                            </StackPanel>
                        </Expander.Header>
                        <StackPanel Margin="0,8,0,0">

                        <!-- Background color -->
                        <Grid Style="{StaticResource SettingRowGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0"
                                           Style="{StaticResource SettingLabel}"
                                           Text="{DynamicResource Appearance_BackgroundColor}"
                                           FontSize="16"/>
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                           Grid.Column="0"
                                           Style="{StaticResource SettingLabel}"
                                           Text="{DynamicResource Appearance_SelectedColor}"
                                           Width="Auto"/>
                                    <TextBox x:Name="BackgroundColorHex"
                                           Grid.Column="1"
                                           Style="{StaticResource PlaceholderTextBox}"
                                           Tag="#RRGGBB"
                                           Width="90" MaxLength="9" TextWrapping="NoWrap"
                                           VerticalAlignment="Center"
                                           KeyDown="ColorHex_KeyDown"
                                           LostFocus="ColorHex_LostFocus"
                                           Margin="0,0,20,0"/>
                                </Grid>

                            </Grid>
                            
                            <StackPanel Grid.Column="1" Width="210">
                                <CheckBox x:Name="BackgroundPalletCheckBox"
                                          Content="{DynamicResource Appearance_ExpandPallet}"
                                          HorizontalAlignment="Right" Margin="0,0,0,2"/>
                                <materialDesign:ColorPicker x:Name="BackgroundColorPicker"
                                                            Width="200" HorizontalAlignment="Right">
                                    <materialDesign:ColorPicker.Style>
                                        <Style TargetType="materialDesign:ColorPicker">
                                            <Setter Property="Height" Value="36" />
                                            <Style.Triggers>
                                                <DataTrigger Value="True">
                                                    <DataTrigger.Binding>
                                                        <Binding Path="IsChecked" Source="{x:Reference BackgroundPalletCheckBox}" />
                                                    </DataTrigger.Binding>
                                                    <DataTrigger.EnterActions>
                                                        <BeginStoryboard HandoffBehavior="SnapshotAndReplace">
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetProperty="Height" To="110" Duration="0:0:0.20">
                                                                    <DoubleAnimation.EasingFunction>
                                                                        <QuadraticEase EasingMode="EaseOut"/>
                                                                    </DoubleAnimation.EasingFunction>
                                                                </DoubleAnimation>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.EnterActions>
                                                    <DataTrigger.ExitActions>
                                                        <BeginStoryboard HandoffBehavior="SnapshotAndReplace">
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetProperty="Height" To="36" Duration="0:0:0.20">
                                                                    <DoubleAnimation.EasingFunction>
                                                                        <QuadraticEase EasingMode="EaseIn"/>
                                                                    </DoubleAnimation.EasingFunction>
                                                                </DoubleAnimation>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.ExitActions>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </materialDesign:ColorPicker.Style>
                                </materialDesign:ColorPicker>
                            </StackPanel>
                        </Grid>

                        <!-- Panels color -->
                        <Grid Style="{StaticResource SettingRowGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0"
                                           Style="{StaticResource SettingLabel}"
                                           Text="{DynamicResource Appearance_PanelsColor}"
                                           FontSize="16"/>
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Style="{StaticResource SettingLabel}"
                                               Text="{DynamicResource Appearance_SelectedColor}"
                                               Width="Auto"/>
                                    <TextBox x:Name="PanelsColorHex"
                                             Grid.Column="1"
                                             Style="{StaticResource PlaceholderTextBox}"
                                             Tag="#RRGGBB"
                                             Width="90" MaxLength="9" TextWrapping="NoWrap"
                                             VerticalAlignment="Center"
                                             KeyDown="ColorHex_KeyDown"
                                             LostFocus="ColorHex_LostFocus"
                                             Margin="0,0,20,0"/>
                                </Grid>
                            </Grid>
                            <StackPanel Grid.Column="1" Width="210">
                                <CheckBox x:Name="PanelsPalletCheckBox"
                                          Content="{DynamicResource Appearance_ExpandPallet}"
                                          HorizontalAlignment="Right" Margin="0,0,0,2"/>
                                <materialDesign:ColorPicker x:Name="PanelsColorPicker"
                                                            Width="200" HorizontalAlignment="Right">
                                    <materialDesign:ColorPicker.Style>
                                        <Style TargetType="materialDesign:ColorPicker">
                                            <Setter Property="Height" Value="36" />
                                            <Style.Triggers>
                                                <DataTrigger Value="True">
                                                    <DataTrigger.Binding>
                                                        <Binding Path="IsChecked" Source="{x:Reference PanelsPalletCheckBox}" />
                                                    </DataTrigger.Binding>
                                                    <DataTrigger.EnterActions>
                                                        <BeginStoryboard HandoffBehavior="SnapshotAndReplace">
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetProperty="Height" To="110" Duration="0:0:0.20">
                                                                    <DoubleAnimation.EasingFunction>
                                                                        <QuadraticEase EasingMode="EaseOut"/>
                                                                    </DoubleAnimation.EasingFunction>
                                                                </DoubleAnimation>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.EnterActions>
                                                    <DataTrigger.ExitActions>
                                                        <BeginStoryboard HandoffBehavior="SnapshotAndReplace">
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetProperty="Height" To="36" Duration="0:0:0.20">
                                                                    <DoubleAnimation.EasingFunction>
                                                                        <QuadraticEase EasingMode="EaseIn"/>
                                                                    </DoubleAnimation.EasingFunction>
                                                                </DoubleAnimation>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.ExitActions>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </materialDesign:ColorPicker.Style>
                                </materialDesign:ColorPicker>
                            </StackPanel>
                        </Grid>

                        <!-- Keys text color -->
                        <Grid Style="{StaticResource SettingRowGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0"
                                           Style="{StaticResource SettingLabel}"
                                           Text="{DynamicResource Appearance_KeysTextColor}"
                                           FontSize="16"/>
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Style="{StaticResource SettingLabel}"
                                               Text="{DynamicResource Appearance_SelectedColor}"
                                               Width="Auto"/>
                                    <TextBox x:Name="KeysColorHex"
                                             Grid.Column="1"
                                             Style="{StaticResource PlaceholderTextBox}"
                                             Tag="#RRGGBB"
                                             Width="90" MaxLength="9" TextWrapping="NoWrap"
                                             VerticalAlignment="Center"
                                             KeyDown="ColorHex_KeyDown"
                                             LostFocus="ColorHex_LostFocus"
                                             Margin="0,0,20,0"/>
                                </Grid>
                            </Grid>
                            <StackPanel Grid.Column="1" Width="210">
                                <CheckBox x:Name="KeyssPalletCheckBox"
                                          Content="{DynamicResource Appearance_ExpandPallet}"
                                          HorizontalAlignment="Right" Margin="0,0,0,2"/>
                                <materialDesign:ColorPicker x:Name="KeysColorPicker"
                                                            Width="200" HorizontalAlignment="Right">
                                    <materialDesign:ColorPicker.Style>
                                        <Style TargetType="materialDesign:ColorPicker">
                                            <Setter Property="Height" Value="36" />
                                            <Style.Triggers>
                                                <DataTrigger Value="True">
                                                    <DataTrigger.Binding>
                                                        <Binding Path="IsChecked" Source="{x:Reference KeyssPalletCheckBox}" />
                                                    </DataTrigger.Binding>
                                                    <DataTrigger.EnterActions>
                                                        <BeginStoryboard HandoffBehavior="SnapshotAndReplace">
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetProperty="Height" To="110" Duration="0:0:0.20">
                                                                    <DoubleAnimation.EasingFunction>
                                                                        <QuadraticEase EasingMode="EaseOut"/>
                                                                    </DoubleAnimation.EasingFunction>
                                                                </DoubleAnimation>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.EnterActions>
                                                    <DataTrigger.ExitActions>
                                                        <BeginStoryboard HandoffBehavior="SnapshotAndReplace">
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetProperty="Height" To="36" Duration="0:0:0.20">
                                                                    <DoubleAnimation.EasingFunction>
                                                                        <QuadraticEase EasingMode="EaseIn"/>
                                                                    </DoubleAnimation.EasingFunction>
                                                                </DoubleAnimation>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.ExitActions>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </materialDesign:ColorPicker.Style>
                                </materialDesign:ColorPicker>
                            </StackPanel>
                        </Grid>

                        <!-- Values text color -->
                        <Grid Style="{StaticResource SettingRowGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0"
                                           Style="{StaticResource SettingLabel}"
                                           Text="{DynamicResource Appearance_ValuesTextColor}"
                                           FontSize="16"/>
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Style="{StaticResource SettingLabel}"
                                               Text="{DynamicResource Appearance_SelectedColor}"
                                               Width="Auto"/>
                                    <TextBox x:Name="ValuesColorHex"
                                             Grid.Column="1"
                                             Style="{StaticResource PlaceholderTextBox}"
                                             Tag="#RRGGBB"
                                             Width="90" MaxLength="9" TextWrapping="NoWrap"
                                             VerticalAlignment="Center"
                                             KeyDown="ColorHex_KeyDown"
                                             LostFocus="ColorHex_LostFocus"
                                             Margin="0,0,20,0"/>
                                </Grid>
                            </Grid>
                            <StackPanel Grid.Column="1" Width="210">
                                <CheckBox x:Name="ValuessPalletCheckBox"
                                          Content="{DynamicResource Appearance_ExpandPallet}"
                                          HorizontalAlignment="Right" Margin="0,0,0,2"/>
                                <materialDesign:ColorPicker x:Name="ValuesColorPicker"
                                                            Width="200" HorizontalAlignment="Right">
                                    <materialDesign:ColorPicker.Style>
                                        <Style TargetType="materialDesign:ColorPicker">
                                            <Setter Property="Height" Value="36" />
                                            <Style.Triggers>
                                                <DataTrigger Value="True">
                                                    <DataTrigger.Binding>
                                                        <Binding Path="IsChecked" Source="{x:Reference ValuessPalletCheckBox}" />
                                                    </DataTrigger.Binding>
                                                    <DataTrigger.EnterActions>
                                                        <BeginStoryboard HandoffBehavior="SnapshotAndReplace">
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetProperty="Height" To="110" Duration="0:0:0.20">
                                                                    <DoubleAnimation.EasingFunction>
                                                                        <QuadraticEase EasingMode="EaseOut"/>
                                                                    </DoubleAnimation.EasingFunction>
                                                                </DoubleAnimation>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.EnterActions>
                                                    <DataTrigger.ExitActions>
                                                        <BeginStoryboard HandoffBehavior="SnapshotAndReplace">
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetProperty="Height" To="36" Duration="0:0:0.20">
                                                                    <DoubleAnimation.EasingFunction>
                                                                        <QuadraticEase EasingMode="EaseIn"/>
                                                                    </DoubleAnimation.EasingFunction>
                                                                </DoubleAnimation>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.ExitActions>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </materialDesign:ColorPicker.Style>
                                </materialDesign:ColorPicker>
                            </StackPanel>
                        </Grid>
                        <!--
                        <TextBlock Text="{DynamicResource Appearance_SaturationNote}"
                                   TextWrapping="Wrap"
                                   FontSize="11"
                                   Margin="0,4,0,0"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                        -->
                        </StackPanel>
                    </Expander>
                </materialDesign:Card>

                <!-- ===================== Fonts (keys + values) ===================== -->
                <materialDesign:Card Margin="0,0,0,12" Padding="12">
                    <Expander IsExpanded="False" Background="Transparent" Padding="0">
                        <Expander.Header>
                            <StackPanel>
                                <TextBlock Style="{StaticResource CardHeader}" Margin="0"
                                           Text="{DynamicResource Appearance_Fonts}"/>
                                <TextBlock Text="{DynamicResource Appearance_FontsDesc}"
                                           FontSize="12" Margin="0,2,0,0" TextWrapping="Wrap"
                                           Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                            </StackPanel>
                        </Expander.Header>
                        <StackPanel Margin="0,8,0,0">
                            <TextBlock Text="{DynamicResource Appearance_KeysFont}"
                                       FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <controls:FontPicker x:Name="KeysFontPicker"/>

                            <TextBlock Text="{DynamicResource Appearance_ValuesFont}"
                                       FontWeight="SemiBold" Margin="0,12,0,4"/>
                            <controls:FontPicker x:Name="ValuesFontPicker"/>
                        </StackPanel>
                    </Expander>
                </materialDesign:Card>

                <!-- ===================== Rainbow background ===================== -->
                <materialDesign:Card Margin="0,0,0,12" Padding="12">
                    <Expander IsExpanded="False" Background="Transparent" Padding="0">
                        <Expander.Header>
                            <StackPanel>
                                <TextBlock Style="{StaticResource CardHeader}" Margin="0"
                                           Text="{DynamicResource Appearance_RainbowBackground}"/>
                                <TextBlock Text="{DynamicResource Appearance_RainbowBackgroundDesc}"
                                           FontSize="12" Margin="0,2,0,0" TextWrapping="Wrap"
                                           Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                            </StackPanel>
                        </Expander.Header>
                        <StackPanel Margin="0,8,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox x:Name="BackgroundRainbowCheckBox"
                                      Grid.Column="0"
                                      VerticalAlignment="Center"
                                      Click="Click_BackgroundRainbowCheckBox"
                                      Content="{DynamicResource Appearance_RainbowBackgroundMode}"/>

                            <!-- Full-cycle duration (1–10 s), to the right of the toggle. -->
                            <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                                <TextBlock FontSize="11"
                                           Foreground="{DynamicResource MaterialDesignBodyLight}">
                                    <Run Text="{DynamicResource Appearance_RainbowSpeed}"/>
                                    <Run Text="{Binding ElementName=RainbowSpeedSlider, Path=Value, StringFormat={}{0:0}}"/><Run Text=" s"/>
                                </TextBlock>
                                <Slider x:Name="RainbowSpeedSlider"
                                        Minimum="1" Maximum="10"
                                        TickFrequency="1" IsSnapToTickEnabled="True"
                                        TickPlacement="BottomRight"
                                        Value="6"
                                        ValueChanged="RainbowSpeedSlider_ValueChanged"/>
                            </StackPanel>
                        </Grid>
                        </StackPanel>
                    </Expander>
                </materialDesign:Card>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <DockPanel Grid.Row="2" Margin="0,8,0,0" LastChildFill="False" Grid.ColumnSpan="2">
            <Button DockPanel.Dock="Right"
                    Margin="8,0,0,0"
                    Content="{DynamicResource Common_Exit}"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    IsCancel="True"
                    Click="Click_Close"/>
            <Button DockPanel.Dock="Right"
                    Margin="8,0,0,0"
                    Content="{DynamicResource Common_Save}"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Click="Click_SaveAndClose"/>
            <Button x:Name="SaveAsButton"
                    DockPanel.Dock="Right"
                    Margin="8,0,0,0"
                    Content="{DynamicResource Common_SaveAs}"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Click="Click_SaveAs"/>
            <Button DockPanel.Dock="Right"
                    Margin="8,0,0,0"
                    Content="{DynamicResource Common_Load}"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Click="Click_Load"/>
        </DockPanel>

        <!-- "Save As" popup: a modal in-window overlay where the user types the
             new profile name and explicitly confirms or cancels. Spans every
             row so it dims the whole window; collapsed until SaveAs is clicked. -->
        <Grid x:Name="SaveAsOverlay" Grid.Row="0" Grid.RowSpan="3"
              Panel.ZIndex="10" Visibility="Collapsed" Background="#80000000"
              Margin="-16" Grid.ColumnSpan="2">
            <materialDesign:Card Width="320" Padding="16"
                                 HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Appearance_SaveAsTitle}"
                               FontWeight="Bold" FontSize="16" Margin="0,0,0,12"/>
                    <Border BorderBrush="#BDBDBD" BorderThickness="1" CornerRadius="3" Padding="4,2,4,2">
                        <TextBox x:Name="SaveAsNameTextBox"
                                 Style="{StaticResource PlaceholderTextBox}"
                                 Tag="{DynamicResource Appearance_SaveAsPlaceholder}"
                                 MaxLength="30" TextWrapping="NoWrap"
                                 KeyDown="SaveAsNameTextBox_KeyDown"/>
                    </Border>
                    <TextBlock x:Name="SaveAsErrorText"
                               Text="{DynamicResource Appearance_SaveAsEmptyError}"
                               Foreground="#D32F2F" FontSize="11"
                               Margin="2,4,0,0" Visibility="Collapsed"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                        <Button Content="{DynamicResource Common_Cancel}"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Margin="0,0,8,0" Click="Click_SaveAsCancel"/>
                        <Button Content="{DynamicResource Common_Save}"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Click="Click_SaveAsConfirm"/>
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>
        </Grid>

    </Grid>

</Window>
