<Application x:Class="ClickyKeys.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:conv="clr-namespace:ClickyKeys.Converters">

    <Application.Resources>
        <ResourceDictionary>

            <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <conv:DivideByConverter x:Key="DivideBy4" Divider="4"/>
            <conv:FontFamilyJsonConverter x:Key="FontFamilyJsonConverter"/>

            <conv:BoolToFontWeightConverter x:Key="BoolToFontWeightConverter" />
            <conv:BoolToFontStyleConverter x:Key="BoolToFontStyleConverter" />
            <conv:BoolToUnderlineConverter x:Key="BoolToUnderlineConverter" />

            <!-- High-quality (Fant) downscaling for every Image. -->
            <Style TargetType="Image">
                <Setter Property="RenderOptions.BitmapScalingMode" Value="HighQuality" />
            </Style>


            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme BaseTheme="Light" PrimaryColor="DeepPurple" SecondaryColor="Lime" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign2.Defaults.xaml" />
                <!-- Baseline localized strings (English); LocalizationManager merges the active language on top at startup, so missing translations fall back to English. -->
                <ResourceDictionary Source="pack://application:,,,/Resources/Strings.en.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
